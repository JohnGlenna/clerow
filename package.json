{
  "name": "clerow",
  "private": true,
  "version": "0.1.0",
  "description": "Clerow — your daily streak to getting recommended by AI",
  "workspaces": [
    "clerow-mobile",
    "clerow-web"
  ],
  "scripts": {
    "web:dev": "npm run dev --workspace=clerow-web",
    "web:build": "npm run build --workspace=clerow-web",
    "mobile:start": "npm run start --workspace=clerow-mobile",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit -p clerow-web && tsc --noEmit -p clerow-mobile",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20"
  }
}
