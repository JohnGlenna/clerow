# Copy to .env.local and fill in. .env.local is gitignored.

# Perplexity — free-scan engine (chat completions, sonar model)
PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Paid-scan engines. Each is optional: a missing key just shows that model as
# locked. Set the model id only to override the sensible default in parentheses.
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx        # ChatGPT (Responses API + web search)
# OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx     # Claude (Messages API + web search)
# ANTHROPIC_MODEL=claude-sonnet-4-5
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx        # Gemini (Google Search grounding)
# GEMINI_MODEL=gemini-2.5-flash

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-or-publishable-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>   # server-only, never exposed to client

# Public site URL (used for auth redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Daily scan cron (app/api/cron/daily-scan). Vercel Cron sends this as a Bearer
# token automatically when set in the project env. Use a long random string.
CRON_SECRET=replace-with-a-long-random-string

# Stripe (test mode) — Dashboard > Developers > API keys
STRIPE_SECRET_KEY=<your-stripe-test-secret-key>
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=<your-stripe-test-publishable-key>
STRIPE_WEBHOOK_SECRET=<from-stripe-listen-or-dashboard-webhooks>
# Recurring price IDs created in Stripe (one per plan)
STRIPE_PRICE_FOUNDER=price_xxxxxxxxxxxx
STRIPE_PRICE_TEAM=price_xxxxxxxxxxxx
STRIPE_PRICE_ENTERPRISE=price_xxxxxxxxxxxx
